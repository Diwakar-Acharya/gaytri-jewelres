---
---

<section id="location" class="relative py-24 md:py-32 bg-obsidian-950">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-stretch">
      
      <!-- Details Card -->
      <div class="lg:col-span-5 flex flex-col justify-between">
        <div>
          <span class="text-xs font-bold tracking-widest text-gold-500 uppercase mb-3 block">Visit Our Store</span>
          <h2 class="font-serif text-3xl md:text-5xl font-bold tracking-tight mb-8">
            Experience Purity <br /><span class="text-gold-gradient">In Person</span>
          </h2>
          
          <!-- Address details -->
          <div class="space-y-6 text-obsidian-300 font-light">
            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-gold-950/50 text-gold-400 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-serif font-bold text-gold-200 text-sm tracking-wider uppercase mb-1">Our Address</h4>
                <p class="text-sm leading-relaxed text-obsidian-300">
                  Gayatri Jewellers<br />
                  88Q3+3X9, Main Road, Near Bombay Cineplex,<br />
                  Gate Bazar, New Settlement, Kharagpur,<br />
                  West Bengal - 721301
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-gold-950/50 text-gold-400 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-serif font-bold text-gold-200 text-sm tracking-wider uppercase mb-1">Phone Number</h4>
                <p class="text-sm text-obsidian-300">
                  <a href="tel:+916263888651" class="hover:text-gold-400 transition-colors">06263888651</a> / 
                  <a href="tel:+916263888651" class="hover:text-gold-400 transition-colors">+91 62638 88651</a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-gold-950/50 text-gold-400 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-serif font-bold text-gold-200 text-sm tracking-wider uppercase mb-1">Showroom Timings</h4>
                <p class="text-sm text-obsidian-300">
                  Open Everyday: 10:30 AM – 9:00 PM
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-gold-500/10 flex flex-col sm:flex-row gap-4">
          <a 
            href="https://maps.google.com/?q=Gayatri+Jewellers+Gate+Bazar+Kharagpur" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex-1 text-center py-4 rounded-xl bg-gradient-to-r from-gold-600 to-gold-400 text-obsidian-950 font-bold uppercase tracking-wider text-xs shadow-md transition-all hover:shadow-[0_0_20px_rgba(212,175,55,0.3)]"
          >
            Open in Google Maps
          </a>
        </div>
      </div>

      <!-- Map Embed Container -->
      <div class="lg:col-span-7 rounded-3xl border border-gold-500/15 overflow-hidden bg-obsidian-900/40 relative min-h-[350px] flex items-center justify-center">
        <!-- Interactive Load Button for Privacy -->
        <div id="map-placeholder" class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center bg-obsidian-950/60 z-10">
          <div class="w-16 h-16 rounded-full border border-gold-500/20 bg-gold-950/20 text-gold-400 flex items-center justify-center mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-gold-200 mb-2">Interactive Location Map</h3>
          <p class="text-xs text-obsidian-400 max-w-sm mb-6 font-light">Loading the map shares data with Google. Click below to load the interactive showroom map.</p>
          <button 
            id="load-map-btn" 
            class="px-6 py-2.5 rounded-full border border-gold-500/30 hover:border-gold-500/80 bg-obsidian-900/80 hover:bg-obsidian-900 text-gold-400 font-semibold text-xs tracking-wider uppercase transition-all"
          >
            Load Map
          </button>
        </div>

        <div id="map-iframe-container" class="w-full h-full min-h-[400px] hidden">
          <!-- Iframe will be injected here on load-map click -->
        </div>
      </div>

    </div>

  </div>
</section>

<script>
  const loadMapBtn = document.getElementById('load-map-btn');
  const placeholder = document.getElementById('map-placeholder');
  const mapContainer = document.getElementById('map-iframe-container');

  loadMapBtn?.addEventListener('click', () => {
    if (mapContainer && placeholder) {
      // Inject standard Google Maps iframe embed
      mapContainer.innerHTML = `
        <iframe 
          title="Gayatri Jewellers Location Map"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3690.875225435985!2d87.32357771146747!3d22.348633979564034!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a1d46ac7dc80a13%3A0xe5433a0df470e9eb!2sGate%20Bazar%20Main%20Rd%2C%20Kharagpur%2C%20West%20Bengal%20721301!5e0!3m2!1sen!2sin!4v1719280000000!5m2!1sen!2sin" 
          width="100%" 
          height="100%" 
          style="border:0; min-height:400px;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      `;
      placeholder.classList.add('hidden');
      mapContainer.classList.remove('hidden');
    }
  });
</script>

  {
    id: "gold-necklace",
    title: "Mughal Royal Choker",
    weight: "48.50 grams",
    purity: "22K Hallmark",
    category: "Gold Bridal",
    svgPath: `<circle cx="120" cy="110" r="45" fill="none" stroke="url(#goldGrad)" stroke-width="4" stroke-dasharray="2 4"/>
              <path d="M70 120 C 70 170, 170 170, 170 120" fill="none" stroke="url(#goldGrad)" stroke-width="12" stroke-linecap="round"/>
              <path d="M85 145 C 85 185, 155 185, 155 145" fill="none" stroke="url(#goldGrad)" stroke-width="6" stroke-dasharray="1 5"/>
              <path d="M120 160 L120 185 M100 150 L95 170 M140 150 L145 170" stroke="url(#goldGrad)" stroke-width="3"/>
              <circle cx="120" cy="190" r="6" fill="url(#goldGrad)"/>
              <circle cx="95" cy="173" r="4" fill="url(#goldGrad)"/>
              <circle cx="145" cy="173" r="4" fill="url(#goldGrad)"/>`
  },
  {
    id: "diamond-ring",
    title: "Empress Solitaire Ring",
    weight: "2.4 Carats",
    purity: "VVS1 Clarity / Platinum",
    category: "Diamond Solitaires",
    svgPath: `<ellipse cx="120" cy="140" rx="35" ry="12" fill="none" stroke="url(#silverGrad)" stroke-width="6"/>
              <path d="M100 135 L120 85 L140 135 Z" fill="none" stroke="url(#silverGrad)" stroke-width="2"/>
              <polygon points="120,65 135,85 120,105 105,85" fill="url(#diamondGrad)" stroke="url(#silverGrad)" stroke-width="2"/>
              <line x1="120" y1="65" x2="120" y2="105" stroke="#ffffff" stroke-width="1" opacity="0.8"/>
              <line x1="105" y1="85" x2="135" y2="85" stroke="#ffffff" stroke-width="1" opacity="0.8"/>`
  },
  {
    id: "antique-earrings",
    title: "Jhumka Drop Earrings",
    weight: "18.20 grams",
    purity: "22K Antique Finish",
    category: "Antique Temple",
    svgPath: `<path d="M120 60 L120 90" stroke="url(#goldGrad)" stroke-width="3"/>
              <circle cx="120" cy="55" r="10" fill="url(#goldGrad)"/>
              <path d="M100 110 C100 90, 140 90, 140 110 Z" fill="url(#goldGrad)"/>
              <path d="M100 110 L140 110" stroke="url(#goldGrad)" stroke-width="4"/>
              <path d="M102 120 L102 135 M111 122 L111 140 M120 122 L120 142 M129 122 L129 140 M138 120 L138 135" stroke="url(#goldGrad)" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="120" cy="146" r="3" fill="#ff4d4d"/>`
  },
  {
    id: "silver-pooja",
    title: "Traditional Pooja Thali",
    weight: "250 grams",
    purity: "925 Sterling Silver",
    category: "Silver Collectibles",
    svgPath: `<circle cx="120" cy="120" r="60" fill="none" stroke="url(#silverGrad)" stroke-width="8"/>
              <circle cx="120" cy="120" r="50" fill="none" stroke="url(#silverGrad)" stroke-width="1" stroke-dasharray="2 3"/>
              <circle cx="120" cy="120" r="25" fill="none" stroke="url(#silverGrad)" stroke-width="3"/>
              <path d="M110 120 L130 120 M120 110 L120 130" stroke="url(#silverGrad)" stroke-width="2"/>
              <circle cx="95" cy="95" r="8" fill="url(#silverGrad)"/>
              <circle cx="145" cy="95" r="8" fill="url(#silverGrad)"/>`
  },
  {
    id: "gold-bangle",
    title: "Mayur Filigree Kada",
    weight: "28.10 grams",
    purity: "22K Gold Hallmark",
    category: "Gold Kada",
    svgPath: `<ellipse cx="120" cy="120" rx="60" ry="25" fill="none" stroke="url(#goldGrad)" stroke-width="12"/>
              <ellipse cx="120" cy="120" rx="58" ry="23" fill="none" stroke="#121212" stroke-width="2"/>
              <path d="M60 120 C 60 100, 70 85, 90 85" fill="none" stroke="url(#goldGrad)" stroke-width="4"/>
              <path d="M180 120 C 180 140, 170 155, 150 155" fill="none" stroke="url(#goldGrad)" stroke-width="4"/>
              <circle cx="90" cy="85" r="5" fill="#00ffff"/>
              <circle cx="150" cy="155" r="5" fill="#00ffff"/>`
  },
  {
    id: "diamond-pendant",
    title: "Celestial Drop Pendant",
    weight: "5.8 grams",
    purity: "18K Gold / VVS Diamond",
    category: "Diamond Elegance",
    svgPath: `<path d="M120 40 L120 90" stroke="url(#silverGrad)" stroke-width="2"/>
              <path d="M105 105 L120 75 L135 105 L120 135 Z" fill="url(#diamondGrad)" stroke="url(#silverGrad)" stroke-width="2"/>
              <circle cx="120" cy="148" r="8" fill="url(#goldGrad)"/>

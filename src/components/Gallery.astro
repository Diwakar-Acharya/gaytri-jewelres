---

<section id="gallery" class="relative py-24 md:py-32 bg-obsidian-950">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    
    <!-- Title Area -->
    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-24">
      <span class="text-xs font-bold tracking-widest text-gold-500 uppercase mb-3 block">Exquisite Catalog</span>
      <h2 class="font-serif text-3xl md:text-5xl font-bold tracking-tight mb-6">
        Signature <span class="text-gold-gradient">Masterpieces</span>
      </h2>
      <p class="text-obsidian-300 font-light leading-relaxed">
        Preview some of our highly requested signature creations. Each ornament represents pristine purity, heavy structural reliability, and breathtaking aesthetics.
      </p>
    </div>

    <!-- Gallery Grid (Masonry look on desktop) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {galleryItems.map((item) => (
        <button 
          class="gallery-trigger group relative rounded-2xl border border-gold-500/10 bg-obsidian-900/20 overflow-hidden text-left focus:outline-none focus:ring-2 focus:ring-gold-500"
          data-id={item.id}
          data-title={item.title}
          data-weight={item.weight}
          data-purity={item.purity}
          data-category={item.category}
          aria-haspopup="dialog"
          aria-label={`View details of ${item.title}`}
        >
          <!-- SVG Container simulating high quality luxury illustration -->
          <div class="w-full aspect-[4/3] bg-gradient-to-b from-obsidian-900 to-obsidian-950 flex items-center justify-center p-6 border-b border-gold-500/5 relative overflow-hidden">
            <!-- Hidden Gradients used in SVGs -->
            <svg class="absolute w-0 h-0" aria-hidden="true">
              <defs>
                <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#f3e5ab" />
                  <stop offset="50%" stop-color="#d4af37" />
                  <stop offset="100%" stop-color="#aa7c11" />
                </linearGradient>
                <linearGradient id="silverGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#ffffff" />
                  <stop offset="50%" stop-color="#cfd8dc" />
                  <stop offset="100%" stop-color="#90a4ae" />
                </linearGradient>
                <linearGradient id="diamondGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#e0f7fa" />
                  <stop offset="50%" stop-color="#80deea" />
                  <stop offset="100%" stop-color="#00acc1" />
                </linearGradient>
              </defs>
            </svg>
            
            <svg viewBox="0 0 24 24" class="w-full h-full max-h-[160px] transform group-hover:scale-105 transition-transform duration-500 ease-out" set:html={item.svgPath} aria-hidden="true" />
            
            <div class="absolute top-4 left-4 bg-obsidian-950/80 backdrop-blur-md px-3 py-1 rounded-full border border-gold-500/10">
              <span class="text-[9px] font-bold tracking-widest text-gold-400 uppercase">{item.category}</span>
            </div>
          </div>

          <!-- Bottom Card Data -->
          <div class="p-6 bg-obsidian-950/50">
            <h3 class="font-serif text-lg font-bold text-gold-100 mb-1 group-hover:text-gold-400 transition-colors">{item.title}</h3>
            <div class="flex items-center justify-between text-xs text-obsidian-400">
              <span>{item.purity}</span>
              <span class="text-gold-500/80 font-serif">{item.weight}</span>
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- Lightbox Modal container -->
    <div 
      id="lightbox" 
      class="fixed inset-0 z-50 bg-obsidian-950/95 backdrop-blur-md hidden items-center justify-center p-4 md:p-10"
      role="dialog" 
      aria-modal="true" 
      aria-labelledby="lightbox-title"
    >
      <button 
        id="lightbox-close" 
        class="absolute top-6 right-6 text-gold-400 hover:text-gold-200 focus:outline-none w-12 h-12 rounded-full border border-gold-500/20 bg-obsidian-900/60 flex items-center justify-center"
        aria-label="Close Lightbox"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="max-w-4xl w-full bg-obsidian-900/60 border border-gold-500/20 rounded-3xl overflow-hidden flex flex-col md:flex-row shadow-2xl">
        <!-- SVG Preview Container -->
        <div class="w-full md:w-1/2 aspect-square bg-gradient-to-b from-obsidian-950 to-obsidian-900 flex items-center justify-center p-10 border-b md:border-b-0 md:border-r border-gold-500/10">
          <svg id="lightbox-svg" viewBox="0 0 24 24" class="w-full h-full max-h-[250px]" aria-hidden="true">
            <!-- Dynamic Injection -->
          </svg>
        </div>
        
        <!-- Metadata Side -->
        <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-between">
          <div>
            <span id="lightbox-category" class="text-xs font-bold tracking-widest text-gold-500 uppercase block mb-2">Category</span>
            <h3 id="lightbox-title" class="font-serif text-2xl md:text-3xl font-bold text-gold-200 mb-6">Ornament Title</h3>
            
            <div class="space-y-4 border-t border-gold-500/10 pt-6">
              <div class="flex justify-between">
                <span class="text-sm text-obsidian-400">Purity Standard</span>
                <span id="lightbox-purity" class="text-sm font-semibold text-gold-300">22K Hallmark</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-obsidian-400">Estimated Weight</span>
                <span id="lightbox-weight" class="text-sm font-semibold text-gold-300 font-serif">45.00g</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-obsidian-400">BIS Certification</span>
                <span class="text-sm text-emerald-400 font-semibold uppercase tracking-wider">HUID Registered</span>
              </div>
            </div>
          </div>

          <div class="mt-8 pt-6 border-t border-gold-500/10 flex flex-col gap-4">
            <a 
              id="lightbox-whatsapp-cta"
              href="#" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="w-full text-center py-3.5 rounded-xl bg-gradient-to-r from-gold-600 to-gold-400 text-obsidian-950 font-bold uppercase tracking-wider text-xs shadow-md"
            >
              Inquire via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.gallery-trigger');
  const lightbox = document.getElementById('lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  
  const lbSvg = document.getElementById('lightbox-svg');
  const lbTitle = document.getElementById('lightbox-title');
  const lbCategory = document.getElementById('lightbox-category');
  const lbPurity = document.getElementById('lightbox-purity');
  const lbWeight = document.getElementById('lightbox-weight');
  const lbWhatsapp = document.getElementById('lightbox-whatsapp-cta') as HTMLAnchorElement;

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const button = trigger as HTMLButtonElement;
      const title = button.getAttribute('data-title') || '';
      const weight = button.getAttribute('data-weight') || '';
      const purity = button.getAttribute('data-purity') || '';
      const category = button.getAttribute('data-category') || '';
      
      // Extract the SVG content inside the trigger's aspect container
      const svgEl = button.querySelector('div > svg:nth-of-type(2)');
      if (svgEl && lbSvg) {
        lbSvg.innerHTML = svgEl.innerHTML;
      }
      
      if (lbTitle) lbTitle.textContent = title;
      if (lbCategory) lbCategory.textContent = category;
      if (lbPurity) lbPurity.textContent = purity;
      if (lbWeight) lbWeight.textContent = weight;

      if (lbWhatsapp) {
        const text = encodeURIComponent(`Hello Gayatri Jewellers, I am interested in previewing the "${title}" (${weight}, ${purity}) shown in your digital catalog.`);
        lbWhatsapp.href = `https://wa.me/916263888651?text=${text}`;
      }

      lightbox?.classList.remove('hidden');
      lightbox?.classList.add('flex');
      document.body.classList.add('overflow-hidden');
    });
  });

  const closeLightbox = () => {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
    document.body.classList.remove('overflow-hidden');
  };

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Support pressing escape to close lightbox
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lightbox?.classList.contains('hidden')) {
      closeLightbox();
    }
  });
</script>

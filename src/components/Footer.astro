---
const currentYear = new Date().getFullYear();
---

<footer class="theme-bg-sec border-t theme-border pt-16 pb-8 theme-text-muted">
  <div class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
    
    <!-- Brand / Column 1 -->
    <div class="space-y-4">
      <a href="#" class="flex items-center gap-2 group" aria-label="Gayatri Jewellers Home">
        <div class="relative w-10 h-10 rounded-full border theme-border flex items-center justify-center bg-gold-950/10 transition-colors group-hover:border-gold-500/60">
          <span class="font-serif font-bold text-lg text-gold-500">G</span>
        </div>
        <div class="flex flex-col">
          <span class="font-serif font-bold tracking-widest text-base text-gold-200">GAYATRI</span>
          <span class="text-[8px] tracking-[0.25em] text-gold-400/80 uppercase font-sans -mt-1">JEWELLERS</span>
        </div>
      </a>
      <p class="text-xs font-light leading-relaxed max-w-xs">
        Exquisite certified gold ornamentals, solitaire diamonds, and fine silver articles in Gate Bazar, Kharagpur. Purity you can trust.
      </p>
    </div>

    <!-- Quick Navigation / Column 2 -->
    <div>
      <h4 class="font-serif font-bold text-gold-300 text-xs tracking-widest uppercase mb-4">Quick Links</h4>
      <ul class="space-y-2.5 text-xs font-light">
        <li><a href="#about" class="hover:text-gold-400 transition-colors">Our Legacy</a></li>
        <li><a href="#collections" class="hover:text-gold-400 transition-colors">Collections</a></li>
        <li><a href="#gallery" class="hover:text-gold-400 transition-colors">Signature Pieces</a></li>
        <li><a href="#testimonials" class="hover:text-gold-400 transition-colors">Client Reviews</a></li>
        <li><a href="#location" class="hover:text-gold-400 transition-colors">Find Showroom</a></li>
      </ul>
    </div>

    <!-- Contact Info / Column 3 -->
    <div>
      <h4 class="font-serif font-bold text-gold-300 text-xs tracking-widest uppercase mb-4">Contact Info</h4>
      <ul class="space-y-3 text-xs font-light">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          <span>Gate Bazar Main Road, Near Bombay Cineplex, New Settlement, Kharagpur - 721301</span>
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href="tel:+916263888651" class="hover:text-gold-400 transition-colors">06263888651</a>
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:gayatri.jewellers.kgp@gmail.com" class="hover:text-gold-400 transition-colors">gayatri.jewellers.kgp@gmail.com</a>
        </li>
      </ul>
    </div>

    <!-- Regulations/Compliance / Column 4 -->
    <div>
      <h4 class="font-serif font-bold text-gold-300 text-xs tracking-widest uppercase mb-4">BIS Certification</h4>
      <p class="text-xs font-light leading-relaxed mb-4">
        We sell exclusively BIS HUID Hallmarked gold items. Customers are encouraged to verify details via the official BIS CARE app.
      </p>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded border border-gold-500/20 bg-gold-950/20 text-[10px] font-bold text-gold-400 uppercase tracking-widest">
        BIS Registered
      </div>
    </div>

  </div>

  <!-- Copyright Block -->
  <div class="max-w-7xl mx-auto px-6 md:px-12 pt-8 border-t theme-border flex flex-col sm:flex-row items-center justify-between gap-4 text-[11px] font-light">
    <div>
      &copy; {currentYear} Gayatri Jewellers. All Rights Reserved.
    </div>
    <div class="flex items-center gap-6">
      <a href="#" class="hover:text-gold-400 transition-colors">Privacy Policy</a>
      <a href="#" class="hover:text-gold-400 transition-colors">Terms of Service</a>
      <span class="text-gold-500/50">Staging Preview Mode</span>
    </div>
  </div>
</footer>

---
---

<section id="about" class="relative py-24 md:py-32 overflow-hidden theme-bg">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      
      <!-- Left Content: Brand Narrative -->
      <div class="lg:col-span-7 flex flex-col justify-center">
        <span class="text-xs font-bold tracking-widest text-gold-500 uppercase mb-3">Our Legacy</span>
        <h2 class="font-serif text-3xl md:text-5xl font-bold tracking-tight mb-8">
          Crafting Heritage & <span class="text-gold-gradient">Timeless Brilliance</span>
        </h2>
        
        <div class="space-y-6 theme-text-muted font-light leading-relaxed text-base md:text-lg">
          <p>
            A legacy of trust, purity, and exquisite craftsmanship in Gate Bazar, Kharagpur. We design heirloom jewelry that celebrates your life's special milestones.
          </p>
          <p>
            Every ornament is certified with the BIS HUID Hallmark, ensuring 100% genuine metal purity and outstanding finish details.
          </p>
        </div>

        <!-- Highlight Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-12">
          <div class="flex items-start gap-4 p-4 rounded-xl border theme-border bg-gold-950/5">
            <div class="p-2 rounded-lg bg-gold-950/20 text-gold-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h4 class="font-serif font-semibold text-gold-200">HUID Certified</h4>
              <p class="text-sm theme-text-muted mt-1 font-light">100% government hallmarked gold matching pure Karat commitments.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 rounded-xl border theme-border bg-gold-950/5">
            <div class="p-2 rounded-lg bg-gold-950/20 text-gold-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-serif font-semibold text-gold-200">Value Guarantee</h4>
              <p class="text-sm theme-text-muted mt-1 font-light">Transparent weight and rate calculations without hidden charges.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Content: Interactive Core Stats & Details -->
      <div class="lg:col-span-5 relative flex justify-center">
        <!-- Background radial glow -->
        <div class="absolute -inset-4 rounded-full bg-gold-500/5 blur-3xl pointer-events-none" aria-hidden="true"></div>

        <div class="relative w-full max-w-md p-8 md:p-10 rounded-2xl border theme-border glass-panel">
          <h3 class="font-serif text-2xl font-bold text-gold-300 mb-8 border-b theme-border pb-4">Our Standards</h3>
          
          <div class="space-y-8">
            <div class="flex items-center justify-between border-b theme-border pb-4">
              <span class="text-sm font-medium tracking-wider theme-text-muted uppercase">HUID Status</span>
              <span class="px-3 py-1 rounded bg-emerald-950/80 text-emerald-400 border border-emerald-500/20 text-xs font-bold uppercase tracking-wider">Active</span>
            </div>

            <div class="flex items-center justify-between border-b theme-border pb-4">
              <span class="text-sm font-medium tracking-wider theme-text-muted uppercase">Available Metals</span>
              <span class="text-sm font-serif font-medium text-gold-200">Gold, Diamond, Silver</span>
            </div>

            <div class="flex items-center justify-between border-b theme-border pb-4">
              <span class="text-sm font-medium tracking-wider theme-text-muted uppercase">Custom Designs</span>
              <span class="text-sm font-serif font-medium text-gold-200">Yes, 5-7 Day Delivery</span>
            </div>

            <div class="flex items-center justify-between border-b theme-border pb-4">
              <span class="text-sm font-medium tracking-wider theme-text-muted uppercase">Huid App</span>
              <span class="text-xs text-gold-400/80 underline font-mono">Via BIS CARE App</span>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-sm font-medium tracking-wider theme-text-muted uppercase">Location</span>
              <span class="text-sm theme-text text-right font-serif">Gate Bazar, Kharagpur</span>
            </div>
          </div>

          <div class="mt-10 p-5 rounded-xl bg-gold-950/10 border theme-border flex items-center gap-4">
            <div class="w-12 h-12 rounded-full border theme-border flex items-center justify-center bg-obsidian-950/80 font-serif text-lg font-bold text-gold-400 shrink-0">
              BIS
            </div>
            <div>
              <h5 class="text-xs font-bold text-gold-300 uppercase tracking-widest">Government Registered</h5>
              <p class="text-[11px] theme-text-muted mt-0.5">Compliant with Bureau of Indian Standards (BIS) directives.</p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</section>

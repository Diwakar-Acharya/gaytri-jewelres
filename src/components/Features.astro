---
const features = [
  {
    title: "100% HUID Hallmarked",
    desc: "Every single gold piece we sell carries the unique 6-digit alphanumeric Government HUID mark, easily verifiable via the BIS Care App.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`
  },
  {
    title: "GIA & IGI Diamonds",
    desc: "Our diamond solitaires and high jewelry pieces are certified by globally renowned grading agencies like GIA and IGI, guaranteeing cut, color, clarity, and carat.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0110 21a3.745 3.745 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0114 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />`
  },
  {
    title: "Transparent Valuation",
    desc: "We calculate gold prices according to live daily bullion market rates, utilizing precise, state-of-the-art gold testing machines for complete weight transparency.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />`
  },
  {
    title: "Lifetime Exchange",
    desc: "Upgrade your jewelry with confidence. We offer high lifetime exchange values on gold and diamonds purchased from us at current store buyback standards.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18" />`
  }
];
---

<section class="relative py-24 bg-obsidian-950">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Headline Content -->
      <div class="lg:col-span-5 flex flex-col justify-center">
        <span class="text-xs font-bold tracking-widest text-gold-500 uppercase mb-3">Our Standards</span>
        <h2 class="font-serif text-3xl md:text-5xl font-bold tracking-tight mb-6">
          The Gayatri <br /><span class="text-gold-gradient">Promise of Purity</span>
        </h2>
        <p class="text-obsidian-300 font-light leading-relaxed mb-8">
          For generations, the cornerstone of our business has been absolute, uncompromised honesty. Discover the mechanisms we employ to ensure you get exactly the purity you pay for.
        </p>
        
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-full border border-gold-500/20 bg-gold-950/20 flex items-center justify-center text-gold-400 shrink-0">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <div>
            <h4 class="font-serif font-bold text-gold-300">100% Trust Certified</h4>
            <p class="text-xs text-obsidian-400 mt-1 font-light">Verification protocols are completely visible to visitors during weight & purity checks.</p>
          </div>
        </div>
      </div>

      <!-- Feature Card Grid -->
      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6">
        {features.map((feature) => (
          <div class="p-6 rounded-2xl border border-gold-500/10 bg-obsidian-900/30 hover:border-gold-500/20 hover:bg-obsidian-900/60 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl border border-gold-500/20 bg-gold-950/20 text-gold-400 flex items-center justify-center mb-6">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={feature.icon} aria-hidden="true" />
            </div>
            <h3 class="font-serif text-lg font-bold text-gold-200 mb-3">{feature.title}</h3>
            <p class="text-sm font-light text-obsidian-300 leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
